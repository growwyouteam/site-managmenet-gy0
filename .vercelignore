# Vercel Ignore File
# Files and directories to ignore during Vercel deployment

# Environment files
.env
.env.local
.env.*.local

# Dependencies
node_modules/

# Build outputs
dist/
build/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Git
.git/
.gitignore

# Documentation (optional - remove if you want docs deployed)
*.md
!README.md
